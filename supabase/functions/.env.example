# ローカル開発用環境変数のテンプレート
# 使い方：このファイルを .env にコピーして、実際の値を設定してください
# cp .env.example .env

# Google API Key (Gemini API用)
# Google Cloud Console (https://console.cloud.google.com/apis/credentials) で取得
# 形式: AIza... で始まる文字列
GOOGLE_API_KEY=your_google_api_key_here

# (Optional) Gemini モデル上書き（未設定時は gemini-3.1-flash-lite → gemini-2.5-flash-lite）
# GA 版を使用すること（preview は 2026-05-25 停止）:
#   gemini-3.1-flash-lite
# 使わない: gemini-3.1-flash-lite-preview
GEMINI_CHEAPEST_MODEL=
GEMINI_FALLBACK_MODEL=

# Groq API Key
# https://console.groq.com/keys で取得
# 形式: gsk_... で始まる文字列
GROQ_API_KEY=your_groq_api_key_here

# (Optional) OCR→Groq でレシピを構造化する際に使うモデル
# 例: llama-3.3-70b-versatile
GROQ_RECIPE_MODEL=

# (Optional) Groqの画像解析( Vision )で使うモデル
# 例: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MODEL=

# OpenAI API Key (ChatGPT用)
# https://platform.openai.com/api-keys で取得
# 形式: sk-... または sk-proj-... で始まる文字列
OPENAI_API_KEY=your_openai_api_key_here
CHATGPT_API_KEY=your_openai_api_key_here

# Perplexity API Key
# https://www.perplexity.ai/settings/api で取得
# 形式: pplx_... または pplx-... で始まる文字列
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Vision API Key (オプション)
VISION_API_KEY=your_vision_api_key_here

# Azure Document Intelligence (PDF/画像解析用)
# どちらか一方の命名でOKです（Functionsによって参照名が違うため両方掲載）
AZURE_DI_ENDPOINT=your_azure_document_intelligence_endpoint_here
AZURE_DI_KEY=your_azure_document_intelligence_key_here
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=your_azure_document_intelligence_endpoint_here
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_document_intelligence_key_here
