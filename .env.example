# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is git-ignored and should never be committed.

# Supabase project URL (Settings > API > Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable anon key (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
